generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ActivityLevel {
  SEDENTARY
  LIGHTLY_ACTIVE
  MODERATELY_ACTIVE
  VERY_ACTIVE
  EXTRA_ACTIVE
}

enum UserRole {
  USER
  ADMIN
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  fullName     String   @map("full_name")
  role         UserRole @default(USER)
  createdAt    DateTime @default(now()) @map("created_at")

  profile Profile?

  foodLogs FoodLog[]

  @@map("users")
}

model Profile {
  id           String @id @default(uuid())
  age          Int
  height       Float
  weight       Float 
  targetWeight Float @map("target_weight")
  calorieGoal  Int    @map("calorie_goal")
  proteinGoal  Int    @map("protein_goal")
  activityLevel ActivityLevel @default(MODERATELY_ACTIVE)

  userId String @unique @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("profiles")
}

model FoodLog {
  id        String @id @default(uuid())
  name      String @map("food_name")
  calories  Float
  protein   Float
  notes     String?
  timestamp DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  userId String @map("user_id")
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("food_logs")
  @@index([userId])
}
